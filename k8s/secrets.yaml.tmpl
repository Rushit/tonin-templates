# ║  DO NOT APPLY THIS FILE UNCHANGED.                                    ║
# ║                                                                       ║
# ║  Replace every REPLACE_ME with a real value before `kubectl apply`.   ║
# ║  Better: do not commit real values to git — apply this file once      ║
# ║  via `kubectl create secret`, or use ExternalSecret / Vault to source ║
# ║  it from a real secret store.                                         ║
# ║                                                                       ║
# ║  This file is added to .gitignore by `tonin k8s generate`.             ║
# ╚═══════════════════════════════════════════════════════════════════════╝
apiVersion: v1
kind: Secret
metadata:
  name: {{ name }}-secrets
  namespace: {{ namespace }}
  labels:
    micro.io/service: {{ name }}
type: Opaque
stringData:
{%- for key in stateful_env_from_secret %}
  {{ key }}: REPLACE_ME
{%- endfor %}
